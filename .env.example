# Configure UMA chave (ou mais de uma). O app escolhe automaticamente pela prioridade.

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# xAI (Grok)
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Request timeout (seconds)
LLM_TIMEOUT_S=30

# App
FLASK_ENV=development
SECRET_KEY=dev-secret-change-me
